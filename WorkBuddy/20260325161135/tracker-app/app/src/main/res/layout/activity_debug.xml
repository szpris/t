<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔧 调试模式"
            android:textColor="#E94560"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- MQTT 状态 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#16213E"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📡 MQTT 状态"
                        android:textColor="#4FC3F7"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvMqttBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未知"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvMqttStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Topic: SM09aZ09aZ/GPSTrackHost/info\nBroker: tcp://xy.nasi.cn:51883"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="收到消息："
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvMqttLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="（等待消息...）"
                    android:textColor="#4CAF50"
                    android:textSize="12sp"
                    android:minLines="2"
                    android:maxLines="6"
                    android:background="#0F3460"
                    android:padding="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 获取当前位置 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#16213E"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 测试上传当前位置"
                    android:textColor="#4FC3F7"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnUploadCurrent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="获取并上传当前位置"
                    android:backgroundTint="#4CAF50"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 手动输入经纬度 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#16213E"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️ 手动输入经纬度"
                    android:textColor="#4FC3F7"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/etLat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="纬度 (如: 39.9042)"
                    android:inputType="numberDecimal|numberSigned"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:backgroundTint="#0F3460"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etLng"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="经度 (如: 116.4074)"
                    android:inputType="numberDecimal|numberSigned"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:backgroundTint="#0F3460"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnGetCurrentLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="获取当前位置填充"
                    android:backgroundTint="#2196F3"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnUploadManual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="上传手动输入的位置"
                    android:backgroundTint="#E94560"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 结果显示 -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="准备就绪"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:padding="16dp"
            android:background="#16213E"/>

    </LinearLayout>
</ScrollView>
