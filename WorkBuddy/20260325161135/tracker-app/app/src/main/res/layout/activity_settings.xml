<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="?attr/homeAsUpIndicator"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:onClick="onBack"
            android:contentDescription="返回"
            android:tint="#FFFFFF"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚙️ 设置"
            android:textColor="#E94560"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- 服务器配置 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌐 服务器配置"
        android:textColor="#4FC3F7"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#16213E"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="服务器地址"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etServerUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="http://track.nasi.cn:55000"
                android:inputType="textUri"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:backgroundTint="#0F3460"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="API 密钥"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etApiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="GPS_TRACKER_API_KEY_2024"
                android:inputType="text"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:backgroundTint="#0F3460"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="设备名称（上报标识）"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvDeviceId"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="读取中..."
                    android:textColor="#E94560"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/btnResetDeviceId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="重置"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 上传策略 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📡 上传策略"
        android:textColor="#4FC3F7"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#16213E"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 最小位移 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="最小位移触发（米）"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <SeekBar
                    android:id="@+id/seekMinDistance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="490"
                    android:progress="190"
                    android:progressTint="#E94560"
                    android:thumbTint="#E94560"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvMinDistance"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="200 米"
                    android:textColor="#E94560"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="end"/>
            </LinearLayout>

            <!-- 最小间隔 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="运动中最大上传间隔（分钟）"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <SeekBar
                    android:id="@+id/seekMinInterval"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="28"
                    android:progress="2"
                    android:progressTint="#4CAF50"
                    android:thumbTint="#4CAF50"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvMinInterval"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="2 分钟"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="end"/>
            </LinearLayout>

            <!-- 运动检测开关 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2A2A4A"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📳 启用运动检测"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="静止时不上传，有运动才上传坐标"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchMotionDetect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="#E94560"
                    android:trackTint="#4A2030"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 说明 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#0D2137"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 上传规则说明"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• 运动检测开启时：静止不上传，运动中位移≥设定值立即上传\n• 运动中距上次上传超过间隔时间，自动上传当前坐标\n• 运动检测关闭时：位移≥设定值 或 超过间隔时间 即上传\n• 网络异常时自动缓存，恢复后自动补传"
                android:textColor="#666666"
                android:textSize="12sp"
                android:lineSpacingExtra="4dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="保存设置"
        android:textSize="16sp"
        android:backgroundTint="#E94560"
        android:padding="14dp"/>

    </LinearLayout>
</ScrollView>
